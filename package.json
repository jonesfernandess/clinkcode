{
  "name": "tg-claudecode-bot",
  "version": "1.0.0",
  "description": "Telegram bot for Claude Code integration",
  "main": "dist/main.js",
  "bin": {
    "clinkcode": "./dist/cli.js",
    "tgcc": "./dist/main.js"
  },
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "start": "vite-node dist/main.js",
    "cli": "vite-node src/cli.ts",
    "dev": "DEBUG=* vite-node --watch src/main.ts",
    "watch": "tsc --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "asr": "cd asr-service && . venv/bin/activate && uvicorn server:app --host 0.0.0.0 --port 8600"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@clack/prompts": "^1.1.0",
    "@gramio/format": "^0.3.3",
    "@gramio/split": "^0.0.1",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@openai/codex-sdk": "^0.116.0",
    "chalk": "^5.6.2",
    "diff": "^8.0.2",
    "diff2html": "^3.4.56",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "markdown-it": "^14.1.0",
    "marked": "^16.1.1",
    "node-fetch": "^3.3.2",
    "p-queue": "^8.1.0",
    "redis": "^5.6.1",
    "simple-git": "^3.28.0",
    "strip-ansi": "^7.1.0",
    "telegraf": "^4.16.3",
    "telegram-format": "^3.1.0",
    "ws": "^8.18.3",
    "zod": "^4.0.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/markdown-it": "^14.1.2",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.17.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-node": "^3.2.4"
  },
  "keywords": [
    "telegram",
    "bot",
    "claude-code",
    "typescript"
  ],
  "author": "nickqiao",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
